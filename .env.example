# 复制本文件为 .env, 并把密码改成你自己的
# .env 文件本身一定要加入 .gitignore, 不要提交到 git

# PostgreSQL / PostGIS
POSTGRES_USER=musicmap
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=musicmap

# MinIO 对象存储
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_real_env

# 第三方 API (Phase 2 以后用,现在留空即可)
LASTFM_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
